model Student {
  id        Int       @id @default(autoincrement())
  school_id Int
  name      String
  dob       DateTime? @default(now())
  roll_no   String?   @default("")
  email     String
  contact   String
  image     String?   @default("https://picsum.photos/200")
  address   String
  status    String    @default("active")
}
